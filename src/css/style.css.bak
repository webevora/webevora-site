@import 'bootstrap/dist/css/bootstrap.min.css';

@font-face {
  font-family: "BungeeLocal";
  src: url("../font/bungee/Bungee-Regular.ttf") format("truetype");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
:root {
  --nav-bg: rgba(255, 255, 255, 0.92);
  --nav-line: rgba(15, 23, 42, 0.08);
  --ink: #0f172a;
  --muted: #475569;
  --accent: #2563eb;
  --page-bg: radial-gradient(120% 120% at 0% 0%, #eff8ff 0%, transparent 48%), radial-gradient(120% 120% at 100% 0%, #f2f4ff 0%, transparent 46%), linear-gradient(180deg, #fcfeff 0%, #f4f8ff 58%, #ffffff 100%);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  font-weight: 400;
  font-style: normal;
  color: var(--ink);
  background: var(--page-bg);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: "BungeeLocal", "Bungee", sans-serif;
  font-weight: 400;
  letter-spacing: -0.01em;
}

.app-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  width: min(1150px, 92%);
  margin: 0 auto;
}

main.container {
  padding-top: 12px;
  flex: 1;
  width: min(1150px, 92%);
}

.header {
  position: sticky;
  top: 0;
  z-index: 40;
  backdrop-filter: none;
  background: rgba(255, 255, 255, 0.90);
  border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 8px 20px rgba(16, 24, 40, 0.03);
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  padding: 14px 0;
}

.brand {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  line-height: 1;
  white-space: nowrap;
}

.brand-logo {
  width: 120px;
  height:auto;
  object-fit: contain;
  flex: 0 0 auto;
}

.nav-links {
  display: flex;
  flex-wrap: nowrap;
  gap: 18px;
  align-items: center;
  justify-content: flex-end;
}

.nav-link {
  text-decoration: none;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  color: var(--muted);
  font-weight: 100;
  font-size: 0.96rem;
  padding: 10px 8px;
  border: 0;
  position: relative;
  transition: color 0.18s ease;
}

.nav-link::before {
  content: '';
  position: absolute;
  top: 4px;
  bottom: 4px;
  left: -8px;
  right: -8px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.08);
  opacity: 0;
  transform: translateY(0);
  transition: opacity 0.16s ease, transform 0.16s ease, background 0.16s ease;
  pointer-events: none;
  z-index: -1;
}

.nav-link:hover {
  color: var(--ink);
}

.nav-link:hover::before {
  opacity: 1;
  transform: translateY(-1px);
  background: linear-gradient(
    90deg,
    rgba(37, 99, 235, 0.12) 0%,
    rgba(6, 182, 212, 0.10) 55%,
    rgba(37, 99, 235, 0.06) 100%
  );
  animation: navBgShimmer 360ms ease both;
}

.nav-link--active {
  color: var(--ink);
}

.nav-link::after {
  content: '';
  position: absolute;
  left: 50%;
  width: 64%;
  right: auto;
  bottom: 4px;
  height: 2px;
  border-radius: 999px;
  background: transparent;
  background-size: 200% 100%;
  background-position: 0% 50%;
  transform: translateX(-50%) scaleX(0);
  transform-origin: center;
  transition: transform 0.18s ease, background 0.18s ease;
  opacity: 0.9;
}

.nav-link:hover::after {
  background: linear-gradient(90deg, rgba(37, 99, 235, 1) 0%, rgba(6, 182, 212, 1) 100%);
  transform: translateX(-50%) scaleX(1);
  animation: underlineGradientShift 420ms ease both;
  filter: drop-shadow(0 0 10px rgba(6, 182, 212, 0.18));
}

.nav-link--active::after {
  background: linear-gradient(90deg, rgba(37, 99, 235, 1) 0%, rgba(6, 182, 212, 1) 100%);
  transform: translateX(-50%) scaleX(1);
  animation: underlineGradientShift 520ms ease both;
  filter: drop-shadow(0 0 12px rgba(6, 182, 212, 0.18));
}

/* Active tab background same as hover, even without hover */
.nav-link--active::before {
  opacity: 1;
  transform: translateY(-1px);
  background: linear-gradient(
    90deg,
    rgba(37, 99, 235, 0.12) 0%,
    rgba(6, 182, 212, 0.10) 55%,
    rgba(37, 99, 235, 0.06) 100%
  );
}

@keyframes navBgShimmer {
  0% {
    opacity: 0.4;
    transform: translateY(0);
    background-position: 0% 50%;
  }
  100% {
    opacity: 1;
    transform: translateY(-1px);
    background-position: 100% 50%;
  }
}

@keyframes underlineGradientShift {
  0% {
    background-position: 0% 50%;
  }
  100% {
    background-position: 100% 50%;
  }
}

/* Vertical separator in the exact middle of the gap */
.nav-sep {
  width: 1px;
  height: 28px;
  background: rgba(15, 23, 42, 0.14);
  align-self: center;
  flex: 0 0 auto;
}

@media (max-width: 720px) {
  .nav {
    flex-direction: column;
    align-items: flex-start;
    padding: 14px 0;
  }

  .nav-links {
    width: 100%;
    gap: 18px;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 4px;
  }

  /* Avoid odd separators on mobile scroll layout */
  .nav-sep {
    display: none;
  }

  .nav-links::-webkit-scrollbar {
    height: 6px;
  }

  .nav-links::-webkit-scrollbar-thumb {
    background: rgba(15, 23, 42, 0.10);
    border-radius: 999px;
  }
}

/* --- Page load overlay --- */
body.page-loading {
  overflow: hidden;
}

.page-loader {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: grid;
  place-items: center;
  background: var(--page-bg);
  transition: opacity 0.38s ease, visibility 0.38s ease;
}

.page-loader--exit {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.page-loader__inner {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loader {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.page-loader__svg {
  display: block;
  width: min(88vw, 520px);
  height: auto;
}

.text {
  font-family: "BungeeLocal", "Bungee", cursive;
  font-size: 200px;
  fill: none;
  stroke: url(#grad);
  stroke-width: 8;
  stroke-dasharray: 1500;
  stroke-dashoffset: 1500;
  animation: draw 2.5s linear infinite;
}

@keyframes draw {
  0% {
    stroke-dashoffset: 1500;
  }
  50% {
    stroke-dashoffset: 0;
  }
  100% {
    stroke-dashoffset: -1500;
  }
}

@media (max-width: 768px) {
  .text {
    font-size: 170px;
  }
}

@media (max-width: 480px) {
  .text {
    font-size: 130px;
    stroke-width: 7;
  }
}

.page-loader__inner {
  transform-origin: center center;
}

.page-loader__inner--exit {
  animation: loaderExitSteps 520ms steps(4, end) forwards;
}

.page-loader--exit .page-loader__svg {
  animation: loaderSvgExitSteps 520ms steps(4, end) forwards;
}

.page-loader--exit .text {
  animation:
    draw 2.5s linear infinite,
    textExitSteps 520ms steps(4, end) forwards;
}

@keyframes loaderExitSteps {
  0% {
    opacity: 1;
    filter: blur(0);
  }
  25% {
    opacity: 0.9;
    filter: blur(0);
  }
  50% {
    opacity: 0.65;
    filter: blur(1px);
  }
  75% {
    opacity: 0.35;
    filter: blur(3px);
  }
  100% {
    opacity: 0;
    filter: blur(6px);
  }
}

@keyframes loaderSvgExitSteps {
  0% {
    transform: translateY(0) scale(1);
  }
  25% {
    transform: translateY(-3px) scale(1.01);
  }
  50% {
    transform: translateY(-8px) scale(0.99);
  }
  75% {
    transform: translateY(-14px) scale(0.96);
  }
  100% {
    transform: translateY(-22px) scale(0.92);
  }
}

@keyframes textExitSteps {
  0% {
    opacity: 1;
    stroke-width: 8;
    stroke-dashoffset: 0;
    filter: drop-shadow(0 0 0 rgba(14, 116, 144, 0));
  }
  25% {
    opacity: 1;
    stroke-width: 8;
    stroke-dashoffset: -180;
    filter: drop-shadow(0 0 10px rgba(14, 116, 144, 0.22));
  }
  50% {
    opacity: 0.8;
    stroke-width: 6;
    stroke-dashoffset: -520;
    filter: drop-shadow(0 0 16px rgba(14, 116, 144, 0.34));
  }
  75% {
    opacity: 0.45;
    stroke-width: 4;
    stroke-dashoffset: -980;
    filter: drop-shadow(0 0 10px rgba(14, 116, 144, 0.18));
  }
  100% {
    opacity: 0;
    stroke-width: 2;
    stroke-dashoffset: -1500;
    filter: drop-shadow(0 0 0 rgba(14, 116, 144, 0));
  }
}

/* --- Footer --- */
.site-footer {
  margin-top: 0;
  position: relative;
  overflow: hidden;
  border-top: 0;
  background: radial-gradient(130% 100% at 100% 0%, rgba(40, 92, 132, 0.28) 0%, transparent 52%), linear-gradient(180deg, #072740 0%, #041e33 100%);
}

.site-footer__wave {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  height: 76px;
  line-height: 0;
  pointer-events: none;
  z-index: 0;
}

.site-footer__wave svg {
  display: block;
  width: 100%;
  height: 100%;
}

.site-footer__inner {
  min-height: 132px;
  display: grid;
  grid-template-columns: 1.4fr auto;
  gap: 14px 28px;
  align-items: center;
  padding: 32px 0 22px;
  position: relative;
  z-index: 1;
}

.site-footer__intro {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 10px 16px;
  align-items: center;
  width: 100%;
}

.site-footer__intro-content {
  display: grid;
  gap: 8px;
}

.site-footer__title {
  margin: 0;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  font-size: clamp(0.92rem, 1.5vw, 1.05rem);
  letter-spacing: 0.02em;
  color: #dfeaf5;
}

.site-footer__logo {
  width: 200px;
  height: auto;
  object-fit: contain;
  flex: 0 0 auto;
}

.site-footer__text {
  margin: 0;
  color: #ccdaea;
  max-width: 62ch;
  font-size: 0.92rem;
}

.site-footer__links {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10px;
}

.site-footer__link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  padding: 0;
  text-decoration: none;
  color: #dae7f2;
  border-radius: 999px;
  border: 1px solid rgba(165, 190, 210, 0.32);
  background: rgba(20, 61, 90, 0.42);
  transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
}

.site-footer__link:hover {
  color: #0f2a42;
  background: #d2dde8;
  border-color: #d2dde8;
}
.site-footer__copy {
  grid-column: 1 / -1;
  margin: 0;
  color: #d8e7f6 !important;
  font-size: 0.84rem;
  border-top: 1px solid rgba(150, 177, 199, 0.24);
  padding-top: 23px;
}

@media (max-width: 720px) {
  .site-footer__inner {
    grid-template-columns: 1fr;
    gap: 12px;
    min-height: 150px;
    padding-top: 46px;
  }

  .site-footer__intro {
    grid-template-columns: auto 1fr;
    gap: 8px 12px;
    align-items: center;
  }

  .site-footer__links {
    justify-content: flex-start;
  }

  .site-footer__copy {
    padding-top: 10px;
  }

  .site-footer__logo {
    width: 120px;
  }
}



/* --- Contact Page --- */
.contact-page {
  position: relative;
  overflow: hidden;
  border-radius: 24px;
  margin: 20px 0 28px;
  padding: clamp(20px, 3vw, 34px);
  background:
    radial-gradient(120% 130% at 0% 0%, rgba(190, 225, 255, 0.28) 0%, transparent 46%),
    radial-gradient(120% 130% at 100% 0%, rgba(209, 220, 255, 0.24) 0%, transparent 50%),
    linear-gradient(180deg, #fbfdff 0%, #f1f7ff 54%, #fbfdff 100%);
  border: 1px solid rgba(132, 169, 206, 0.22);
  box-shadow: 0 18px 42px rgba(15, 37, 61, 0.12);
  isolation: isolate;
}

.contact-bg {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  z-index: -1;
  opacity: 0.52;
  animation: contactOrbFloat 9s ease-in-out infinite;
}

.contact-bg--one {
  width: 320px;
  height: 320px;
  top: -130px;
  right: -90px;
  background: radial-gradient(circle at 35% 35%, rgba(125, 170, 220, 0.3) 0%, rgba(125, 170, 220, 0.02) 72%);
}

.contact-bg--two {
  width: 260px;
  height: 260px;
  bottom: -120px;
  left: -70px;
  animation-delay: -1.4s;
  background: radial-gradient(circle at 45% 45%, rgba(155, 190, 225, 0.28) 0%, rgba(155, 190, 225, 0.02) 74%);
}

.contact-top,
.contact-grid {
  animation: contactReveal 620ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.contact-grid {
  animation-delay: 120ms;
}

.contact-top {
  border-radius: 16px;
  padding: clamp(18px, 2.2vw, 28px);
  border: 1px solid rgba(122, 163, 202, 0.3);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(243, 250, 255, 0.94) 100%);
  transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
}

.contact-top:hover {
  transform: translateY(-2px);
  border-color: rgba(88, 141, 190, 0.44);
  box-shadow: 0 12px 26px rgba(35, 76, 114, 0.14);
}

.contact-kicker {
  margin: 0;
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 14px;
  font-size: 0.78rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #e9f4ff;
  background: linear-gradient(90deg, #133451 0%, #1a4569 100%);
  border: 1px solid rgba(94, 138, 176, 0.58);
}

.contact-title {
  margin: 12px 0 10px;
  color: #102f4c;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  line-height: 1.24;
  font-size: clamp(1.34rem, 2.4vw, 2rem);
}

.contact-subtitle {
  margin: 0;
  max-width: 72ch;
  color: #3a5874;
  line-height: 1.65;
  font-size: 1.04rem;
}

.contact-grid {
  margin-top: 18px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

.contact-panel,
.contact-form-wrap {
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(133, 170, 207, 0.24);
  box-shadow: 0 8px 20px rgba(24, 50, 78, 0.08);
  transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
}

.contact-panel:hover,
.contact-form-wrap:hover {
  transform: translateY(-2px);
  border-color: rgba(90, 145, 196, 0.42);
  box-shadow: 0 14px 30px rgba(31, 66, 100, 0.14);
}

.contact-panel {
  padding: 18px;
}

.contact-panel__title {
  margin: 0;
  color: #143754;
  font-size: 1.06rem;
}

.contact-panel__text {
  margin: 10px 0 0;
  color: #4a6783;
  line-height: 1.55;
  font-size: 0.95rem;
}

.contact-quick-list {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  margin-top: 18px;
  margin-bottom: 6px;
}

.contact-quick {
  position: relative;
  overflow: visible;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 10px;
  text-align: center;
  text-decoration: none;
  color: inherit;
  border: 0;
  background: transparent;
  border-radius: 14px;
  min-height: 168px;
  padding: 22px 16px;
  transform: translateY(0);
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  animation: contactItemIn 520ms ease both;
  --icon-tilt: -8deg;
}

.contact-quick:not(:last-child)::after {
  content: "";
  position: absolute;
  right: -10px;
  top: 0;
  height: 100%;
  border-right: 2px dotted rgba(64, 115, 160, 0.45);
  pointer-events: none;
}

.contact-quick:hover {
  transform: translateY(-3px);
}

.contact-quick:nth-child(1) { animation-delay: 60ms; }
.contact-quick:nth-child(2) { animation-delay: 120ms; }
.contact-quick:nth-child(3) { animation-delay: 180ms; }
.contact-quick:nth-child(4) { animation-delay: 240ms; }

.contact-quick:nth-child(1) { --icon-tilt: -12deg; }
.contact-quick:nth-child(2) { --icon-tilt: 10deg; }
.contact-quick:nth-child(3) { --icon-tilt: -9deg; }
.contact-quick:nth-child(4) { --icon-tilt: 12deg; }

.contact-quick__icon {
  width: auto;
  height: auto;
  display: inline-grid;
  place-items: center;
  color: #1e4f7b;
  background: none;
  transition: transform 0.26s cubic-bezier(0.2, 0.8, 0.2, 1), color 0.26s ease, filter 0.26s ease;
  font-size: 3.4rem;
  flex: 0 0 auto;
}

.contact-quick:hover .contact-quick__icon {
  transform: translateY(-4px) scale(1.14) rotate(var(--icon-tilt));
  color: #153d61;
  filter: drop-shadow(0 8px 10px rgba(35, 87, 133, 0.25));
}

.contact-quick__meta {
  display: grid;
  gap: 4px;
  justify-items: center;
}

.contact-quick__label {
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: #56738e;
  font-weight: 600;
  line-height: 1.1;
}

.contact-quick__value {
  font-size: 1.02rem;
  color: #143b59;
  line-height: 1.2;
}

.contact-note {
  margin-top: 22px;
  color: #4b6884;
  font-size: 0.89rem;
  line-height: 1.55;
}

.contact-form-wrap {
  padding: 18px;
  background: #ffffff;
  border: 1px solid rgba(108, 150, 188, 0.28);
  box-shadow: 0 10px 24px rgba(28, 61, 93, 0.1);
}

.contact-form {
  display: grid;
  gap: 12px;
}

.contact-form__row {
  display: grid;
  gap: 7px;
  animation: contactItemIn 520ms ease both;
}

.contact-form__row:nth-child(1) { animation-delay: 80ms; }
.contact-form__row:nth-child(2) { animation-delay: 140ms; }
.contact-form__row:nth-child(3) { animation-delay: 200ms; }
.contact-form__row:nth-child(4) { animation-delay: 260ms; }

.contact-form__row--two {
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.contact-label {
  color: #264a6d;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  font-weight: 600;
}

.contact-input {
  width: 100%;
  border: 1px solid rgba(112, 154, 191, 0.48);
  border-radius: 12px;
  padding: 12px;
  font-size: 0.95rem;
  color: #173e5e;
  background: #ffffff;
  transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease, background 0.2s ease;
}

.contact-input:hover {
  border-color: rgba(67, 126, 179, 0.7);
  background: #fcfeff;
}

.contact-input::placeholder {
  color: #6f8da8;
}

.contact-input:focus {
  outline: none;
  border-color: rgba(40, 104, 161, 0.92);
  box-shadow: 0 0 0 4px rgba(152, 191, 224, 0.42);
  transform: translateY(-1px);
}

.contact-input--textarea {
  min-height: 130px;
  resize: vertical;
}

.contact-submit {
  margin-top: 2px;
  border: 0;
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 0.95rem;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  letter-spacing: 0.04em;
  color: #f5fbff;
  cursor: pointer;
  background: linear-gradient(90deg, #0f2f4c 0%, #174768 55%, #225c87 100%);
  box-shadow: 0 10px 22px rgba(16, 52, 81, 0.44);
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

.contact-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(16, 52, 81, 0.54);
  filter: brightness(1.06);
}

.contact-submit:active {
  transform: translateY(0);
}

@keyframes contactReveal {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes contactItemIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes contactOrbFloat {
  0% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(-8px, 10px, 0) scale(1.03);
  }
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@media (max-width: 960px) {
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .contact-quick-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .contact-quick::after {
    content: none;
  }

  .contact-form__row--two {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 620px) {
  .contact-page {
    border-radius: 18px;
    margin: 14px 0 20px;
    padding: 16px;
  }

  .contact-top {
    border-radius: 14px;
    padding: 16px;
  }

  .contact-title {
    font-size: 1.16rem;
  }

  .contact-quick-list {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .contact-subtitle {
    font-size: 0.96rem;
  }
}




/* --- About Page --- */
.about-page {
  margin: 20px 0 28px;
  border-radius: 24px;
  padding: clamp(20px, 3vw, 34px);
  background:
    radial-gradient(120% 130% at 0% 0%, rgba(191, 229, 255, 0.24) 0%, transparent 50%),
    radial-gradient(120% 130% at 100% 0%, rgba(215, 225, 255, 0.2) 0%, transparent 54%),
    linear-gradient(180deg, #fcfeff 0%, #f2f8ff 55%, #ffffff 100%);
  border: 1px solid rgba(134, 171, 207, 0.22);
  box-shadow: 0 18px 42px rgba(15, 37, 61, 0.12);
}

.about-hero,
.about-highlights,
.about-values,
.about-cta {
  animation: aboutReveal 600ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.about-highlights {
  animation-delay: 100ms;
}

.about-values {
  animation-delay: 170ms;
}

.about-cta {
  animation-delay: 240ms;
}

.about-kicker {
  margin: 0;
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 14px;
  font-size: 0.78rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #e9f4ff;
  background: linear-gradient(90deg, #133451 0%, #1a4569 100%);
  border: 1px solid rgba(94, 138, 176, 0.58);
}

.about-title {
  margin: 12px 0 10px;
  color: #102f4c;
  line-height: 1.24;
  font-size: clamp(1.34rem, 2.4vw, 2rem);
}

.about-subtitle {
  margin: 0;
  max-width: 74ch;
  color: #3a5874;
  line-height: 1.65;
  font-size: 1.04rem;
}

.about-highlights {
  margin-top: 18px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.about-highlight-card {
  border-radius: 16px;
  padding: 16px;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(133, 170, 207, 0.24);
  box-shadow: 0 8px 20px rgba(24, 50, 78, 0.08);
  transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
}

.about-highlight-card:hover {
  transform: translateY(-2px);
  border-color: rgba(90, 145, 196, 0.42);
  box-shadow: 0 14px 30px rgba(31, 66, 100, 0.14);
}

.about-highlight-value {
  margin: 0;
  color: #143754;
  font-size: clamp(1.2rem, 2.2vw, 1.8rem);
}

.about-highlight-label {
  margin: 8px 0 0;
  color: #4a6783;
  font-size: 0.95rem;
}

.about-values {
  margin-top: 16px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.about-value-card {
  border-radius: 16px;
  padding: 16px;
  background: #ffffff;
  border: 1px solid rgba(108, 150, 188, 0.28);
  box-shadow: 0 10px 24px rgba(28, 61, 93, 0.1);
  transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
}

.about-value-card:hover {
  transform: translateY(-2px);
  border-color: rgba(90, 145, 196, 0.42);
  box-shadow: 0 14px 30px rgba(31, 66, 100, 0.14);
}

.about-value-title {
  margin: 0;
  color: #143754;
  font-size: 1.04rem;
}

.about-value-text {
  margin: 10px 0 0;
  color: #4a6783;
  line-height: 1.58;
  font-size: 0.95rem;
}

.about-cta {
  margin-top: 16px;
  border-radius: 16px;
  padding: clamp(16px, 2vw, 24px);
  border: 1px solid rgba(122, 163, 202, 0.3);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(243, 250, 255, 0.94) 100%);
}

.about-cta-title {
  margin: 0;
  color: #113350;
  font-size: clamp(1.1rem, 2vw, 1.5rem);
}

.about-cta-text {
  margin: 10px 0 14px;
  color: #456581;
  line-height: 1.6;
}

.about-cta-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  border: 0;
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 0.95rem;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  letter-spacing: 0.04em;
  color: #f5fbff;
  background: linear-gradient(90deg, #0f2f4c 0%, #174768 55%, #225c87 100%);
  box-shadow: 0 10px 22px rgba(16, 52, 81, 0.44);
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

.about-cta-link:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(16, 52, 81, 0.54);
  filter: brightness(1.06);
  color: #f5fbff;
}

@keyframes aboutReveal {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 900px) {
  .about-highlights,
  .about-values {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 620px) {
  .about-page {
    border-radius: 18px;
    margin: 14px 0 20px;
    padding: 16px;
  }

  .about-title {
    font-size: 1.16rem;
  }

  .about-subtitle {
    font-size: 0.96rem;
  }
}

/* --- Services Page --- */
.services-page {
  margin: 20px 0 28px;
  border-radius: 24px;
  padding: clamp(20px, 3vw, 34px);
  background:
    radial-gradient(120% 130% at 0% 0%, rgba(192, 230, 255, 0.24) 0%, transparent 50%),
    radial-gradient(120% 130% at 100% 0%, rgba(214, 225, 255, 0.2) 0%, transparent 54%),
    linear-gradient(180deg, #fcfeff 0%, #f3f8ff 54%, #ffffff 100%);
  border: 1px solid rgba(134, 171, 207, 0.22);
  box-shadow: 0 18px 42px rgba(15, 37, 61, 0.12);
}

.services-top,
.services-grid,
.services-cta {
  animation: servicesReveal 620ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.services-grid {
  animation-delay: 120ms;
}

.services-cta {
  animation-delay: 220ms;
}

.services-kicker {
  margin: 0;
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 14px;
  font-size: 0.78rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #e8fbff;
  background: linear-gradient(90deg, rgba(37, 99, 235, 0.25) 0%, rgba(6, 182, 212, 0.18) 100%);
  border: 1px solid rgba(56, 189, 248, 0.35);
}

.services-title {
  margin: 12px 0 10px;
  color: #e9f9ff;
  line-height: 1.24;
  font-size: clamp(1.34rem, 2.4vw, 2rem);
}

.services-subtitle {
  margin: 0;
  max-width: 72ch;
  color: rgba(215, 243, 255, 0.78);
  line-height: 1.65;
  font-size: 1.04rem;
}

.services-grid {
  margin-top: 18px;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
  padding: 10px 0 6px;
}

.service-card {
  border-radius: 22px;
  padding: 18px;
  background: linear-gradient(180deg, rgba(19, 44, 63, 0.82) 0%, rgba(4, 10, 18, 0.96) 100%);
  border: 1px solid rgba(56, 189, 248, 0.24);
  box-shadow:
    0 18px 60px rgba(0, 0, 0, 0.35),
    inset 0 0 0 1px rgba(37, 99, 235, 0.08);
  transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease, filter 0.28s ease;
  transform-style: preserve-3d;
  position: relative;
  overflow: hidden;
  animation: serviceCardEnter 720ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.service-card:hover {
  transform: perspective(900px) rotateX(6deg) rotateY(-8deg) translateY(-6px);
  border-color: rgba(6, 182, 212, 0.42);
  box-shadow:
    0 28px 84px rgba(0, 0, 0, 0.48),
    inset 0 0 0 1px rgba(37, 99, 235, 0.14);
}

.service-card__icon {
  width: 48px;
  height: 48px;
  display: inline-grid;
  place-items: center;
  border-radius: 12px;
  font-size: 1.3rem;
  color: #e8fbff;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.55) 0%, rgba(6, 182, 212, 0.45) 100%);
  box-shadow: 0 14px 26px rgba(6, 182, 212, 0.18);
}

.service-card__title {
  margin: 12px 0 8px;
  color: #e9fbff;
  font-size: 1.02rem;
}

.service-card__text {
  margin: 0;
  color: rgba(210, 242, 255, 0.78);
  line-height: 1.58;
  font-size: 0.95rem;
}

.service-card::before {
  content: '';
  position: absolute;
  inset: -2px;
  background:
    radial-gradient(420px 120px at 18% 0%, rgba(6, 182, 212, 0.18), transparent 60%),
    radial-gradient(420px 120px at 82% 0%, rgba(37, 99, 235, 0.18), transparent 55%);
  opacity: 0.9;
  pointer-events: none;
}

.service-card > * {
  position: relative;
  z-index: 1;
}

.service-card:nth-child(1) {
  animation-delay: 60ms;
}
.service-card:nth-child(2) {
  animation-delay: 120ms;
}
.service-card:nth-child(3) {
  animation-delay: 180ms;
}
.service-card:nth-child(4) {
  animation-delay: 240ms;
}

@keyframes serviceCardEnter {
  from {
    opacity: 0;
    transform: perspective(900px) translateY(22px) rotateX(8deg) scale(0.98);
    filter: blur(4px);
  }
  to {
    opacity: 1;
    transform: perspective(900px) translateY(0) rotateX(0deg) scale(1);
    filter: blur(0px);
  }
}

.services-cta {
  margin-top: 16px;
  border-radius: 16px;
  padding: clamp(16px, 2vw, 24px);
  border: 1px solid rgba(122, 163, 202, 0.3);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(243, 250, 255, 0.94) 100%);
}

.services-cta__title {
  margin: 0;
  color: #113350;
  font-size: clamp(1.1rem, 2vw, 1.4rem);
}

.services-cta__text {
  margin: 10px 0 14px;
  color: #456581;
  line-height: 1.6;
}

.services-cta__link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  border: 0;
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 0.95rem;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  letter-spacing: 0.04em;
  color: #f5fbff;
  background: linear-gradient(90deg, #0f2f4c 0%, #174768 55%, #225c87 100%);
  box-shadow: 0 10px 22px rgba(16, 52, 81, 0.44);
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

.services-cta__link:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(16, 52, 81, 0.54);
  filter: brightness(1.06);
  color: #f5fbff;
}

@keyframes servicesReveal {
  from {
    opacity: 0;
    transform: translateY(18px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 960px) {
  .services-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .services-page {
    border-radius: 18px;
    margin: 14px 0 20px;
    padding: 16px;
  }

  .services-title {
    font-size: 1.16rem;
  }

  .services-subtitle {
    font-size: 0.96rem;
  }

  .services-grid {
    grid-template-columns: 1fr;
  }
}

/* --- About + Contact Enhanced Animations --- */
.about-hero--grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 18px;
  align-items: center;
}

.about-hero-copy {
  animation: aboutSlideLeft 760ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.about-photo-wrap {
  margin: 0;
  border-radius: 18px;
  padding: 14px;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96) 0%, rgba(236, 246, 255, 0.95) 100%);
  border: 1px solid rgba(121, 163, 201, 0.36);
  box-shadow: 0 20px 36px rgba(24, 63, 99, 0.18);
  animation: aboutSlideRight 760ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.about-photo {
  width: 100%;
  height: clamp(220px, 30vw, 320px);
  object-fit: cover;
  border-radius: 12px;
  display: block;
  animation: softFloat 6.4s ease-in-out infinite;
}

.about-values .about-value-card:nth-child(1) {
  animation: aboutPopIn 620ms ease both;
  animation-delay: 160ms;
}

.about-values .about-value-card:nth-child(2) {
  animation: aboutPopIn 620ms ease both;
  animation-delay: 260ms;
}

.about-values .about-value-card:nth-child(3) {
  animation: aboutPopIn 620ms ease both;
  animation-delay: 360ms;
}

.contact-top-layout {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  align-items: center;
  gap: 18px;
}

.contact-top-copy {
  animation: aboutSlideLeft 760ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.contact-photo-wrap {
  margin: 0;
  border-radius: 18px;
  padding: 12px;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98) 0%, rgba(236, 246, 255, 0.95) 100%);
  border: 1px solid rgba(109, 153, 193, 0.34);
  box-shadow: 0 16px 32px rgba(22, 59, 93, 0.16);
  animation: aboutSlideRight 760ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.contact-photo {
  width: 100%;
  height: clamp(210px, 27vw, 300px);
  object-fit: cover;
  border-radius: 12px;
  display: block;
  animation: softFloat 6.8s ease-in-out infinite;
}

.contact-panel,
.contact-form-wrap {
  animation: aboutPopIn 700ms ease both;
}

.contact-form-wrap {
  animation-delay: 140ms;
}

@keyframes aboutSlideLeft {
  from {
    opacity: 0;
    transform: translateX(-26px) translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateX(0) translateY(0);
  }
}

@keyframes aboutSlideRight {
  from {
    opacity: 0;
    transform: translateX(26px) translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateX(0) translateY(0);
  }
}

@keyframes aboutPopIn {
  from {
    opacity: 0;
    transform: translateY(18px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes softFloat {
  0% {
    transform: translateY(0) scale(1);
    filter: drop-shadow(0 8px 14px rgba(33, 90, 137, 0.14));
  }
  50% {
    transform: translateY(-8px) scale(1.01);
    filter: drop-shadow(0 14px 22px rgba(33, 90, 137, 0.2));
  }
  100% {
    transform: translateY(0) scale(1);
    filter: drop-shadow(0 8px 14px rgba(33, 90, 137, 0.14));
  }
}

@media (max-width: 960px) {
  .about-hero--grid,
  .contact-top-layout {
    grid-template-columns: 1fr;
  }

  .about-photo,
  .contact-photo {
    height: clamp(200px, 42vw, 280px);
  }
}

@media (max-width: 620px) {
  .about-photo-wrap,
  .contact-photo-wrap {
    padding: 10px;
    border-radius: 14px;
  }
}


/* --- About Mission & Vision Slider --- */
.about-purpose {
  margin-top: 0;
  display: block;
}

.about-purpose-section {
  margin: 10px 0;
  padding: 0;
}

.about-page--top {
  margin: 20px 0 10px;
}

.about-page--bottom {
  margin: 10px 0 28px;
}

.about-purpose-slider {
  position: relative;
}

.about-purpose-slide {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 14px;
  border-radius: 16px;
  padding: 14px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(122, 163, 202, 0.3);
  box-shadow: 0 10px 24px rgba(28, 61, 93, 0.1);
  opacity: 0;
  transform: translateY(10px);
  pointer-events: none;
  position: absolute;
  inset: 0;
  transition: opacity 0.35s ease, transform 0.35s ease;
}

.about-purpose-slide--active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
  position: relative;
}

.about-purpose-media {
  margin: 0;
  border-radius: 12px;
  overflow: hidden;
  min-height: 240px;
}

.about-purpose-image {
  width: 100%;
  height: 100%;
  min-height: 240px;
  object-fit: cover;
  display: block;
}

.about-purpose-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.about-purpose-label {
  margin: 0;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 0.74rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #eaf5ff;
  background: linear-gradient(90deg, #123451 0%, #1a4569 100%);
}

.about-purpose-icon {
  width: auto;
  height: auto;
  border-radius: 0;
  display: inline-grid;
  place-items: center;
  font-size: 1.45rem;
  color: #ffffff;
  background: transparent;
  box-shadow: none;
  line-height: 1;
}

.about-purpose-title {
  margin: 10px 0 8px;
  color: #143754;
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  line-height: 1.35;
}

.about-purpose-text {
  margin: 0;
  color: #4a6783;
  line-height: 1.6;
  font-size: 1rem;
}

.about-purpose-controls {
  margin-top: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.about-purpose-btn {
  width: 38px;
  height: 38px;
  border-radius: 999px;
  border: 1px solid rgba(103, 147, 186, 0.35);
  background: #ffffff;
  color: #163d60;
  display: inline-grid;
  place-items: center;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.about-purpose-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px rgba(28, 61, 93, 0.16);
  background: #f5faff;
}

.about-purpose-dots {
  display: flex;
  align-items: center;
  gap: 8px;
}

.about-purpose-dot {
  width: 9px;
  height: 9px;
  border-radius: 999px;
  border: 0;
  background: rgba(79, 119, 153, 0.35);
  cursor: pointer;
  transition: transform 0.2s ease, background 0.2s ease;
}

.about-purpose-dot--active {
  width: 24px;
  background: linear-gradient(90deg, #123451 0%, #1a4569 100%);
}

@media (max-width: 900px) {
  .about-purpose-slide {
    grid-template-columns: 1fr;
  }

  .about-purpose-media,
  .about-purpose-image {
    min-height: 190px;
  }
}







/* --- About CTA Cards --- */
.about-cta--cards {
  margin-top: 16px;
  display: grid;
  grid-template-columns: 1.2fr 1fr auto;
  gap: 14px;
  border: 0;
  background: transparent;
  padding: 0;
}

.about-cta-card {
  border-radius: 16px;
  padding: clamp(16px, 2vw, 24px);
  border: 1px solid rgba(122, 163, 202, 0.3);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(243, 250, 255, 0.94) 100%);
  box-shadow: 0 10px 24px rgba(28, 61, 93, 0.1);
}

.about-cta-subtitle {
  margin: 0;
  color: #113350;
  font-size: 1.02rem;
}

.about-cta-card--action {
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-cta-card--action .about-cta-link {
  margin: 0;
}

@media (max-width: 960px) {
  .about-cta--cards {
    grid-template-columns: 1fr;
  }

  .about-cta-card--action {
    justify-content: flex-start;
  }
}

/* --- About Redesign --- */
.about-redesign {
  margin: 18px 0 28px;
  display: grid;
  gap: 16px;
}

.ar-hero,
.ar-purpose,
.ar-pillar-grid,
.ar-flow,
.ar-cta {
  border-radius: 20px;
  border: 1px solid rgba(130, 168, 204, 0.24);
  box-shadow: 0 16px 34px rgba(22, 50, 78, 0.12);
  background:
    radial-gradient(130% 110% at 0% 0%, rgba(197, 230, 255, 0.2) 0%, transparent 52%),
    linear-gradient(180deg, #fcfeff 0%, #f2f8ff 58%, #ffffff 100%);
}

.ar-hero {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 16px;
  padding: clamp(18px, 2.5vw, 28px);
}

.ar-hero__copy {
  align-self: center;
}

.ar-badge {
  margin: 0;
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 14px;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #e9f4ff;
  background: linear-gradient(90deg, #123451 0%, #1b4a6f 100%);
}

.ar-title {
  margin: 12px 0 10px;
  color: #0f2f4a;
  font-size: clamp(1.34rem, 2.5vw, 2.15rem);
  line-height: 1.2;
}

.ar-subtitle {
  margin: 0;
  color: #3f607e;
  font-size: 1.02rem;
  line-height: 1.66;
}

.ar-chips {
  margin-top: 14px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.ar-chip {
  border-radius: 999px;
  padding: 7px 12px;
  font-size: 0.78rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #214769;
  background: rgba(217, 235, 250, 0.62);
  border: 1px solid rgba(122, 163, 202, 0.32);
}

.ar-actions {
  margin-top: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.ar-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 12px;
  padding: 11px 16px;
  text-decoration: none;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  font-size: 0.9rem;
  letter-spacing: 0.03em;
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease, background 0.22s ease;
}

.ar-btn--primary {
  color: #f7fbff;
  background: linear-gradient(90deg, #0f2f4c 0%, #18496d 60%, #23608f 100%);
  box-shadow: 0 10px 20px rgba(16, 52, 81, 0.38);
}

.ar-btn--primary:hover {
  color: #f7fbff;
  transform: translateY(-2px);
  filter: brightness(1.04);
  box-shadow: 0 13px 24px rgba(16, 52, 81, 0.48);
}

.ar-btn--ghost {
  color: #20496b;
  background: #ffffff;
  border: 1px solid rgba(112, 156, 194, 0.42);
}

.ar-btn--ghost:hover {
  color: #153a5a;
  transform: translateY(-2px);
  box-shadow: 0 10px 18px rgba(28, 61, 93, 0.14);
}

.ar-hero__media {
  margin: 0;
  border-radius: 16px;
  overflow: hidden;
  min-height: 280px;
}

.ar-hero__image {
  width: 100%;
  height: 100%;
  min-height: 280px;
  object-fit: cover;
  display: block;
  transform: scale(1.02);
}

.ar-purpose {
  padding: 14px;
}

.ar-purpose__slide {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 14px;
  border-radius: 16px;
  padding: 12px;
  border: 1px solid rgba(122, 163, 202, 0.26);
  background: rgba(255, 255, 255, 0.92);
  opacity: 0;
  transform: translateY(8px);
  pointer-events: none;
  position: absolute;
  inset: 14px;
  transition: opacity 0.35s ease, transform 0.35s ease;
}

.ar-purpose__slide--active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
  position: relative;
  inset: auto;
}

.ar-purpose__media {
  margin: 0;
  border-radius: 12px;
  overflow: hidden;
  min-height: 250px;
}

.ar-purpose__image {
  width: 100%;
  height: 100%;
  min-height: 250px;
  object-fit: cover;
  display: block;
}

.ar-purpose__content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.ar-purpose__label {
  margin: 0;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  width: fit-content;
  border-radius: 999px;
  padding: 7px 12px;
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #eff8ff;
  background: linear-gradient(90deg, #123451 0%, #1b4a6f 100%);
}

.ar-purpose__icon {
  display: inline-grid;
  place-items: center;
  font-size: 1.35rem;
  line-height: 1;
}

.ar-purpose__title {
  margin: 10px 0 8px;
  color: #123856;
  font-size: clamp(1.1rem, 2.2vw, 1.6rem);
  line-height: 1.3;
}

.ar-purpose__text {
  margin: 0;
  color: #476786;
  line-height: 1.64;
  font-size: 1rem;
}

.ar-purpose__controls {
  margin-top: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
}

.ar-control {
  width: 38px;
  height: 38px;
  border-radius: 999px;
  border: 1px solid rgba(103, 147, 186, 0.4);
  background: #ffffff;
  color: #183f61;
  display: inline-grid;
  place-items: center;
  cursor: pointer;
}

.ar-control:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px rgba(28, 61, 93, 0.16);
}

.ar-dots {
  display: flex;
  align-items: center;
  gap: 8px;
}

.ar-dot {
  width: 9px;
  height: 9px;
  border-radius: 999px;
  border: 0;
  background: rgba(79, 119, 153, 0.35);
  cursor: pointer;
}

.ar-dot--active {
  width: 24px;
  background: linear-gradient(90deg, #123451 0%, #1b4a6f 100%);
}

.ar-pillar-grid {
  padding: clamp(16px, 2vw, 22px);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.ar-pillar-card {
  border-radius: 14px;
  padding: 16px;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(128, 166, 200, 0.3);
}

.ar-pillar-card__title {
  margin: 0;
  color: #113653;
  font-size: 1.02rem;
}

.ar-pillar-card__text {
  margin: 10px 0 0;
  color: #496988;
  line-height: 1.6;
}

.ar-flow {
  padding: clamp(16px, 2vw, 22px);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.ar-step {
  border-radius: 14px;
  padding: 16px;
  border: 1px solid rgba(128, 166, 200, 0.3);
  background: rgba(255, 255, 255, 0.95);
}

.ar-step__icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: inline-grid;
  place-items: center;
  font-size: 2rem;
  color: #f2fbff;
  background: linear-gradient(135deg, #123451 0%, #215c87 100%);
}

.ar-step__title {
  margin: 12px 0 8px;
  color: #113653;
  font-size: 1.02rem;
}

.ar-step__text {
  margin: 0;
  color: #496988;
  line-height: 1.6;
}

.ar-cta {
  padding: clamp(18px, 2.5vw, 26px);
  text-align: left;
}

.ar-cta__title {
  margin: 0;
  color: #113653;
  font-size: clamp(1.15rem, 2.2vw, 1.7rem);
}

.ar-cta__text {
  margin: 10px 0 14px;
  color: #456684;
  line-height: 1.6;
  max-width: 70ch;
}

@media (max-width: 1020px) {
  .ar-hero,
  .ar-purpose__slide {
    grid-template-columns: 1fr;
  }

  .ar-hero__media,
  .ar-hero__image,
  .ar-purpose__media,
  .ar-purpose__image {
    min-height: 220px;
  }

  .ar-pillar-grid,
  .ar-flow {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 680px) {
  .about-redesign {
    margin: 12px 0 18px;
    gap: 12px;
  }

  .ar-hero,
  .ar-purpose,
  .ar-pillar-grid,
  .ar-flow,
  .ar-cta {
    border-radius: 16px;
  }

  .ar-pillar-grid,
  .ar-flow {
    grid-template-columns: 1fr;
  }

  .ar-title {
    font-size: 1.2rem;
  }

  .ar-subtitle,
  .ar-purpose__text,
  .ar-pillar-card__text,
  .ar-step__text,
  .ar-cta__text {
    font-size: 0.95rem;
  }
}

/* --- About Section Headings --- */
.ar-section-head {
  padding: 0 6px;
}

.ar-section-head__kicker {
  margin: 0;
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 6px 11px;
  font-size: 0.72rem;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  color: #eaf5ff;
  background: linear-gradient(90deg, #123451 0%, #1b4a6f 100%);
}

.ar-section-head__title {
  margin: 10px 0 0;
  color: #123856;
  font-size: clamp(1.03rem, 2vw, 1.4rem);
  line-height: 1.3;
}

/* --- About Section Visual Cleanup --- */
.ar-section-head {
  padding: 0 2px;
  margin-top: 2px;
}

.ar-section-head__kicker {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  border: 0;
  color: #4c6e8d;
  font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  font-weight: 700;
  font-size: 0.76rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.ar-section-head__title {
  margin: 6px 0 2px;
  color: #103553;
  font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  font-weight: 800;
  font-size: clamp(1.12rem, 2vw, 1.42rem);
  line-height: 1.26;
  letter-spacing: 0.01em;
  text-transform: none;
}

.ar-pillar-grid,
.ar-flow {
  border: 0;
  box-shadow: none;
  background: transparent;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.ar-pillar-card,
.ar-step {
  border-radius: 16px;
  padding: 18px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(129, 168, 202, 0.35);
  box-shadow: 0 8px 18px rgba(28, 61, 93, 0.08);
}

.ar-pillar-card__title,
.ar-step__title {
  margin: 0;
  color: #113653;
  font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  font-size: 1.06rem;
  font-weight: 800;
  letter-spacing: 0;
  text-transform: none;
}

.ar-pillar-card__text,
.ar-step__text {
  margin: 10px 0 0;
  color: #436585;
  line-height: 1.62;
  font-size: 0.99rem;
}

.ar-step__icon {
  width: 46px;
  height: 46px;
  border-radius: 12px;
  display: inline-grid;
  place-items: center;
  font-size: 2rem;
  color: #f2fbff;
  background: linear-gradient(135deg, #123451 0%, #225f8d 100%);
}

.ar-step__title {
  margin-top: 12px;
}

@media (max-width: 1020px) {
  .ar-pillar-grid,
  .ar-flow {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 680px) {
  .ar-pillar-grid,
  .ar-flow {
    grid-template-columns: 1fr;
  }
}

/* --- About Dark Theme (Mission/Vision Only) --- */
.ar-purpose {
  background:
    radial-gradient(140% 110% at 0% 0%, rgba(39, 71, 103, 0.42) 0%, transparent 52%),
    linear-gradient(180deg, #122233 0%, #162b40 100%);
  border: 1px solid rgba(110, 150, 190, 0.3);
  box-shadow: 0 18px 34px rgba(0, 0, 0, 0.36);
}

.ar-purpose__slide {
  background: rgba(13, 28, 43, 0.7);
  border: 1px solid rgba(121, 163, 199, 0.34);
}

.ar-purpose__label {
  background: linear-gradient(90deg, #1f4c74 0%, #2d6d9d 100%);
  color: #ecf6ff;
}

.ar-purpose__title {
  color: #e8f2ff;
}

.ar-purpose__text {
  color: #b6cae0;
}

.ar-control {
  background: #15314a;
  border: 1px solid rgba(121, 163, 199, 0.44);
  color: #e7f3ff;
}

.ar-control:hover {
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
}

.ar-dot {
  background: rgba(132, 173, 208, 0.42);
}

.ar-dot--active {
  background: linear-gradient(90deg, #3b7daf 0%, #62a6d8 100%);
}
/* --- About Strengths/Process Final Polish --- */
.ar-block {
  border-radius: 20px;
  border: 1px solid rgba(122, 163, 202, 0.28);
  background:
    radial-gradient(140% 120% at 0% 0%, rgba(198, 229, 255, 0.2) 0%, transparent 56%),
    linear-gradient(180deg, #f8fcff 0%, #eef5fd 100%);
  box-shadow: 0 14px 28px rgba(17, 46, 73, 0.12);
  padding: clamp(14px, 2vw, 20px);
}

.ar-section-head--center {
  text-align: center;
  padding: 4px 6px 12px;
}

.ar-section-head--center .ar-section-head__title {
  margin: 0;
  font-size: clamp(1.24rem, 2.2vw, 1.75rem);
  color: #0f3554;
  letter-spacing: 0.01em;
}

.ar-section-head__subtitle {
  margin: 8px 0 0;
  color: #4d6f8d;
  font-size: 0.98rem;
}

.ar-block .ar-pillar-grid,
.ar-block .ar-flow {
  margin-top: 2px;
}

.ar-pillar-card,
.ar-step {
  background: #ffffff;
  border: 1px solid rgba(133, 171, 205, 0.34);
  box-shadow: 0 8px 18px rgba(23, 55, 85, 0.08);
  border-radius: 14px;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.ar-pillar-card:hover,
.ar-step:hover {
  transform: translateY(-3px);
  border-color: rgba(96, 146, 188, 0.52);
  box-shadow: 0 14px 24px rgba(21, 49, 75, 0.14);
}

.ar-pillar-card__title,
.ar-step__title {
  color: #123b5c;
  font-weight: 800;
}

.ar-pillar-card__text,
.ar-step__text {
  color: #3f6384;
}



.ar-section-head__title--bungee {
  font-family: "BungeeLocal", "Bungee", sans-serif;
  letter-spacing: 0.01em;
}




/* --- Pillar Icons --- */
.ar-pillar-card__icon {
  width: 46px;
  height: 46px;
  border-radius: 12px;
  display: inline-grid;
  place-items: center;
  font-size: 1.35rem;
  color: #ecf7ff;
  background: linear-gradient(135deg, #123451 0%, #2a6fa1 100%);
  box-shadow: 0 8px 16px rgba(22, 59, 93, 0.26);
}

.ar-pillar-card__title {
  margin-top: 12px;
}

/* --- Why Choose Us: 2x2 Layout --- */
.ar-block--strengths .ar-pillar-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

@media (max-width: 1200px) {
  .ar-block--strengths .ar-pillar-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 680px) {
  .ar-block--strengths .ar-pillar-grid {
    grid-template-columns: 1fr;
  }
}


/* --- Home Page --- */
.home-page {
  margin: 18px 0 28px;
  display: grid;
  gap: 14px;
}

.home-hero,
.home-services,
.home-highlights,
.home-cta {
  border-radius: 20px;
  border: 1px solid rgba(130, 168, 204, 0.24);
  box-shadow: 0 16px 34px rgba(22, 50, 78, 0.12);
  background:
    radial-gradient(130% 110% at 0% 0%, rgba(197, 230, 255, 0.2) 0%, transparent 52%),
    linear-gradient(180deg, #fcfeff 0%, #f2f8ff 58%, #ffffff 100%);
}

.home-hero {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 16px;
  padding: clamp(18px, 2.4vw, 28px);
}

.home-hero__copy {
  animation: homeSlideLeft 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.home-kicker {
  margin: 0;
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 14px;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #e9f4ff;
  background: linear-gradient(90deg, #123451 0%, #1b4a6f 100%);
}

.home-title {
  margin: 12px 0 10px;
  color: #103553;
  line-height: 1.2;
  font-size: clamp(1.34rem, 2.6vw, 2.2rem);
}

.home-subtitle {
  margin: 0;
  color: #436585;
  line-height: 1.66;
  font-size: 1.02rem;
}

.home-actions {
  margin-top: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.home-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 12px;
  padding: 11px 16px;
  text-decoration: none;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  font-size: 0.88rem;
  letter-spacing: 0.03em;
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

.home-btn--primary {
  color: #f7fbff;
  background: linear-gradient(90deg, #0f2f4c 0%, #18496d 60%, #23608f 100%);
  box-shadow: 0 10px 20px rgba(16, 52, 81, 0.38);
}

.home-btn--primary:hover {
  color: #f7fbff;
  transform: translateY(-2px);
  filter: brightness(1.04);
}

.home-btn--secondary {
  color: #1a4466;
  background: #ffffff;
  border: 1px solid rgba(112, 156, 194, 0.42);
}

.home-btn--secondary:hover {
  color: #123857;
  transform: translateY(-2px);
  box-shadow: 0 10px 18px rgba(28, 61, 93, 0.14);
}

.home-hero__media {
  margin: 0;
  border-radius: 16px;
  overflow: hidden;
  min-height: 280px;
  animation: homeSlideRight 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.home-hero__image {
  width: 100%;
  height: 100%;
  min-height: 280px;
  object-fit: cover;
  display: block;
}

.home-services {
  padding: clamp(14px, 2vw, 20px);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.home-service-card {
  border-radius: 14px;
  padding: 14px;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(133, 171, 205, 0.34);
  display: flex;
  align-items: center;
  gap: 10px;
  animation: homePopIn 620ms ease both;
}

.home-service-card:nth-child(1) { animation-delay: 60ms; }
.home-service-card:nth-child(2) { animation-delay: 100ms; }
.home-service-card:nth-child(3) { animation-delay: 140ms; }
.home-service-card:nth-child(4) { animation-delay: 180ms; }
.home-service-card:nth-child(5) { animation-delay: 220ms; }
.home-service-card:nth-child(6) { animation-delay: 260ms; }

.home-service-card__icon {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  display: inline-grid;
  place-items: center;
  color: #f2fbff;
  background: linear-gradient(135deg, #123451 0%, #2a6fa1 100%);
  font-size: 1.08rem;
}

.home-service-card__title {
  margin: 0;
  color: #103553;
  font-size: 0.98rem;
}

.home-highlights {
  padding: clamp(14px, 2vw, 20px);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.home-highlight-card {
  border-radius: 14px;
  padding: 16px;
  background: #ffffff;
  border: 1px solid rgba(133, 171, 205, 0.34);
  box-shadow: 0 8px 18px rgba(23, 55, 85, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.home-highlight-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 14px 24px rgba(21, 49, 75, 0.14);
}

.home-highlight-card__icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: inline-grid;
  place-items: center;
  font-size: 1.2rem;
  color: #f2fbff;
  background: linear-gradient(135deg, #123451 0%, #225f8d 100%);
}

.home-highlight-card__title {
  margin: 12px 0 8px;
  color: #123b5c;
  font-size: 1.02rem;
}

.home-highlight-card__text {
  margin: 0;
  color: #3f6384;
  line-height: 1.62;
}

.home-cta {
  padding: clamp(18px, 2.5vw, 26px);
  text-align: left;
  animation: homePopIn 680ms ease both;
}

.home-cta__title {
  margin: 0;
  color: #113653;
  font-size: clamp(1.15rem, 2.2vw, 1.72rem);
}

.home-cta__text {
  margin: 10px 0 14px;
  color: #456684;
  line-height: 1.6;
  max-width: 70ch;
}

@keyframes homeSlideLeft {
  from {
    opacity: 0;
    transform: translateX(-24px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes homeSlideRight {
  from {
    opacity: 0;
    transform: translateX(24px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes homePopIn {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 1020px) {
  .home-hero {
    grid-template-columns: 1fr;
  }

  .home-hero__media,
  .home-hero__image {
    min-height: 220px;
  }

  .home-services,
  .home-highlights {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 680px) {
  .home-page {
    margin: 12px 0 18px;
    gap: 12px;
  }

  .home-hero,
  .home-services,
  .home-highlights,
  .home-cta {
    border-radius: 16px;
  }

  .home-services,
  .home-highlights {
    grid-template-columns: 1fr;
  }

  .home-title {
    font-size: 1.2rem;
  }

  .home-subtitle,
  .home-highlight-card__text,
  .home-cta__text {
    font-size: 0.95rem;
  }
}

/* --- About Mission Vision Split Scroll --- */
.ar-belief {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 18px;
  padding: clamp(18px, 2.5vw, 26px);
  border-radius: 20px;
  border: 1px solid rgba(86, 130, 170, 0.42);
  background:
    radial-gradient(130% 120% at 10% 0%, rgba(48, 97, 143, 0.34) 0%, transparent 52%),
    radial-gradient(120% 100% at 100% 100%, rgba(29, 72, 110, 0.28) 0%, transparent 54%),
    linear-gradient(180deg, #071e31 0%, #0b2740 100%);
  box-shadow: 0 18px 36px rgba(0, 0, 0, 0.34);
}

.ar-belief__left {
  position: sticky;
  top: 94px;
  align-self: start;
}

.ar-belief__kicker {
  margin: 0;
  color: #87abc9;
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
}

.ar-belief__title {
  margin: 8px 0 10px;
  color: #f0f7ff;
  font-size: clamp(1.6rem, 3vw, 3rem);
  line-height: 1.05;
  text-transform: uppercase;
}

.ar-belief__title span {
  color: #39d4f6;
}

.ar-belief__text {
  margin: 0;
  color: #c1d7ea;
  line-height: 1.7;
  max-width: 42ch;
}

.ar-belief__cta {
  margin-top: 18px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  letter-spacing: 0.03em;
  border-radius: 14px;
  padding: 12px 18px;
  background: linear-gradient(90deg, #17c3e0 0%, #2bd8f4 100%);
  color: #01273d;
  box-shadow: 0 12px 22px rgba(17, 195, 225, 0.25);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.ar-belief__cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 16px 28px rgba(17, 195, 225, 0.34);
}

.ar-belief__right {
  max-height: none;
  overflow-y: visible;
  padding-right: 0;
  display: grid;
  gap: 14px;
  scroll-snap-type: none;
}

.ar-belief__right::-webkit-scrollbar {
  width: 0;
}

.ar-belief__right::-webkit-scrollbar-thumb {
  background: transparent;
  border-radius: 999px;
}

.ar-belief-card {
  scroll-snap-align: initial;
  border-radius: 18px;
  border: 1px solid rgba(139, 190, 225, 0.34);
  background: linear-gradient(180deg, rgba(129, 194, 217, 0.24) 0%, rgba(87, 149, 172, 0.22) 100%);
  min-height: auto;
  padding: clamp(16px, 2vw, 24px);
  box-shadow: inset 0 0 0 1px rgba(207, 235, 255, 0.06);
}

.ar-belief-card__label {
  margin: 0;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: #eef8ff;
  font-family: "BungeeLocal", "Bungee", sans-serif;
  font-size: clamp(1rem, 1.8vw, 1.35rem);
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.ar-belief-card__icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: inline-grid;
  place-items: center;
  font-size: 1.35rem;
  color: #39d4f6;
  border: 1px solid rgba(143, 219, 239, 0.45);
  background: rgba(5, 30, 46, 0.34);
}

.ar-belief-card__title {
  margin: 12px 0 10px;
  color: #f2f8ff;
  font-size: clamp(1.05rem, 1.8vw, 1.35rem);
  line-height: 1.35;
}

.ar-belief-card__text {
  margin: 0;
  color: #d4e8f8;
  line-height: 1.72;
}

@media (max-width: 1020px) {
  .ar-belief {
    grid-template-columns: 1fr;
  }

  .ar-belief__left {
    position: static;
  }

  .ar-belief__right {
    max-height: none;
    overflow: visible;
    padding-right: 0;
  }

  .ar-belief-card {
    min-height: 0;
  }
}
